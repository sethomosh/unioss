# UNIOSS Environment Configuration
# Copy this file to .env and adjust values for your environment

# --- Database (MySQL) ---
MYSQL_ROOT_PASSWORD=unioss_root_pass
MYSQL_DATABASE=unioss_db
MYSQL_USER=unioss_user
MYSQL_PASSWORD=unioss_pass
MYSQL_HOST=db  # Use 'db' for Docker, 'localhost' for local dev
MYSQL_PORT=3306

# --- Backend API ---
BACKEND_PORT=5000
FLASK_ENV=production  # development or production
# SECRET_KEY=generate_a_random_string_here

# --- SNMP Simulator ---
SNMP_SIM_PORT=1611
SNMP_COMMUNITY=public

# --- Discovery & Polling ---
# Interval for discovery scan (seconds)
DISCOVERY_INTERVAL=3600
# Interval for metric polling (seconds)
POLLING_INTERVAL=15

# --- Frontend ---
VITE_API_URL=http://localhost:5000/api
