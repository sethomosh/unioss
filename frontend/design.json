  "typography": {
    "fonts": {
      "sans": "Montserrat, sans-serif",
      "serif": "Merriweather, serif",
      "mono": "Ubuntu Mono, monospace"
    },
    "weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem"
  },
  "borderRadius": {
    "sm": "calc(var(--radius) - 4px)",
    "md": "calc(var(--radius) - 2px)",
    "lg": "var(--radius)",
    "xl": "calc(var(--radius) + 4px)"
  },
  "shadows": {
    "2xs": "0px 6px 12px -3px hsl(0 0% 0% / 0.04)",
    "xs": "0px 6px 12px -3px hsl(0 0% 0% / 0.04)",
    "sm": "0px 6px 12px -3px hsl(0 0% 0% / 0.09), 0px 1px 2px -4px hsl(0 0% 0% / 0.09)",
    "md": "0px 6px 12px -3px hsl(0 0% 0% / 0.09), 0px 2px 4px -4px hsl(0 0% 0% / 0.09)",
    "lg": "0px 6px 12px -3px hsl(0 0% 0% / 0.09), 0px 4px 6px -4px hsl(0 0% 0% / 0.09)",
    "xl": "0px 6px 12px -3px hsl(0 0% 0% / 0.09), 0px 8px 10px -4px hsl(0 0% 0% / 0.09)",
    "2xl": "0px 6px 12px -3px hsl(0 0% 0% / 0.22)"
  },
  "components": {
    "glass-card": {
      "background": "rgba(255, 255, 255, 0.1)",
      "backdrop-filter": "blur(10px)",
      "border": "1px solid rgba(255, 255, 255, 0.2)",
      "border-radius": "var(--radius)",
      "box-shadow": "var(--shadow-lg)"
    },
    "dark-glass-card": {
      "background": "rgba(0, 0, 0, 0.2)",
      "backdrop-filter": "blur(10px)",
      "border": "1px solid rgba(255, 255, 255, 0.1)",
      "border-radius": "var(--radius)",
      "box-shadow": "var(--shadow-lg)"
    }
  }
} 
